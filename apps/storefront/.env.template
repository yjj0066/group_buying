# ===========================================
# 로컬 개발용 (apps/storefront/.env.local)
# ===========================================

NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_DEFAULT_REGION=kr
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_NAME=공동구매몰

NODE_ENV=development

# Mock/sessionStorage fallback (offline UI dev only). Leave unset/false to persist via Medusa → Supabase Postgres.
# NEXT_PUBLIC_ENABLE_MOCK_FALLBACK=false

# ===========================================
# Flask AI/search engine (Hybrid API)
# ===========================================
# Local dev: Flask is OFF by default (avoids 2.5s timeout when :5000 is down).
# Start Flask, then set SEARCH_API_ENABLED=true
SEARCH_API_ENABLED=false
NEXT_PUBLIC_SEARCH_API_URL=http://localhost:5000
# Legacy aliases (still supported):
# AI_ENGINE_URL=http://localhost:5000
# NEXT_PUBLIC_AI_ENGINE_URL=http://localhost:5000
# AI_ENGINE_ENABLED=true
# Optional: FLASK_REQUEST_TIMEOUT_MS=800
# Medusa group-deal search feed (Flask crawler): GET /store/group-deals/search-index

# ===========================================
# Stripe (결제 연동 시)
# NEXT_PUBLIC_STRIPE_KEY=

# 토스페이먼츠 (한국 리전)
# NEXT_PUBLIC_TOSS_CLIENT_KEY=
# NEXT_PUBLIC_TOSS_WIDGET_VARIANT_KEY=
# NEXT_PUBLIC_TOSS_AGREEMENT_VARIANT_KEY=
