# ===========================================
# 로컬 개발용 환경 변수 (apps/backend/.env)
# 배포 시에는 .env.production.template 참고
# ===========================================

# 스토어프론트 도메인 (쉼표로 여러 개 가능)
STORE_CORS=http://localhost:8000

# Admin / 인증 CORS
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000

# 로컬 개발용 시크릿 (배포 시 반드시 변경!)
JWT_SECRET=dev-jwt-secret-change-in-production
COOKIE_SECRET=dev-cookie-secret-change-in-production

# PostgreSQL
# 로컬: postgres://postgres:postgres@localhost:5432/group_buying
# Supabase: Project Settings → Database → Connection string (URI)
#   - 마이그레이션: Direct connection (포트 5432)
#   - 앱 실행: Transaction pooler (포트 6543) 권장
DATABASE_URL=postgres://postgres:postgres@localhost:5432/group_buying

# Supabase 등 원격 DB 사용 시 true (로컬 Postgres면 비우거나 false)
# DATABASE_SSL=true

# Redis (로컬에서는 비워두면 in-memory 사용)
# REDIS_URL=redis://localhost:6379

# Worker mode: shared | server | worker
# MEDUSA_WORKER_MODE=shared

# ===========================================
# Flask AI/search engine sync (Hybrid API)
# ===========================================
# Flask가 상품 인덱스를 가져갈 때 사용하는 Medusa store base URL
# STORE_PUBLIC_URL=http://localhost:9000

# ===========================================
# 토스페이먼츠 (한국 리전 전용)
# ===========================================
TOSS_TEST_MODE=true
TOSS_WEBHOOK_SECRET=
TOSS_SUPPORTED_COUNTRIES=kr

# 토스페이먼츠 API 키
TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=

# 빌링키 암호화 전용 시크릿 (미설정 시 COOKIE_SECRET 사용)
BILLING_KEY_ENCRYPTION_SECRET=

# 공동구매 빌링키 캡처 재시도 횟수
PG_CAPTURE_MAX_RETRIES=3

# ===========================================
# Stripe (해외 리전 공동구매 SetupIntent 예약)
# ===========================================
STRIPE_TEST_MODE=true
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# 비우면 한국(kr) 제외 전체 허용. 예: us,gb,de,jp
STRIPE_SUPPORTED_COUNTRIES=
