# ===========================================
# Document AI (Upstage via Flask BFF) — 로컬/스테이징
# apps/backend/.env 에 아래 블록을 복사해 사용
# ===========================================

# stub 끄고 BFF 사용 (개발 모드에서는 반드시 true)
DOCUMENT_AI_ENABLED=true

# Document AI BFF URL (services/document-ai-bff)
HYBRID_API_URL=http://127.0.0.1:5000

# Medusa ↔ BFF 공유 시크릿 (BFF .env 와 동일)
HYBRID_API_SHARED_SECRET=dev-shared-secret-change-me

# BFF/Upstage가 /static/receipts 이미지를 fetch할 때 사용
MEDUSA_BACKEND_URL=http://localhost:9000

# confidence >= 0.85 이면 자동 parsed (그 미만은 needs_review)
DOCUMENT_AI_AUTO_VERIFY_CONFIDENCE=0.85

# Upstage + Parse 지연 대비 (ms)
DOCUMENT_AI_REQUEST_TIMEOUT_MS=60000
