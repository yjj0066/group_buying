# Upstage
UPSTAGE_API_KEY=

# Medusa BFF auth (must match HYBRID_API_SHARED_SECRET on Medusa)
HYBRID_SHARED_SECRET=dev-shared-secret-change-me

# receipt-extraction | custom-schema
UPSTAGE_RECEIPT_MODE=custom-schema

# Upstage request timeout (seconds)
UPSTAGE_TIMEOUT_SEC=90

# Set true to run Document Parse before IE (slower, ~2x Upstage calls)
RECEIPT_USE_DOCUMENT_PARSE=false

# Flask
PORT=5000
FLASK_DEBUG=false
